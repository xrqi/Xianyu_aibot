# ============================================
# XianyuBot 环境变量配置示例
# 复制此文件为 .env 并填入你的实际配置
# ============================================

# --------------------------------------------
# API 配置（必填）
# --------------------------------------------

# OpenAI 兼容 API 密钥
# 阿里云百炼: https://bailian.console.aliyun.com/
OPENAI_API_KEY=your_api_key_here

# API 基础 URL
# 阿里云通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# 其他 OpenAI 兼容服务请填写对应地址
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --------------------------------------------
# 大模型配置（选填）
# --------------------------------------------

# 主模型 - 用于生成回复
# 可选: qwen-max(最强), qwen-plus(平衡), qwen-turbo(快速), qwen3-flash(极速)
LLM_MODEL=qwen3-flash

# 轻量级模型 - 用于简单任务
LLM_MODEL_LIGHT=qwen3-flash

# 温度参数 - 控制回复创意性 (0.0-2.0)
# 越低越保守，越高越创意
LLM_TEMPERATURE=0.7

# 是否启用批量处理
BATCH_PROCESSING=True

# --------------------------------------------
# 闲鱼配置（通常无需修改）
# --------------------------------------------

# 系统会自动管理闲鱼登录凭证，不需要手动设置
# cookies 将保存在 data/xianyu_cookies.json

# --------------------------------------------
# 日志配置（选填）
# --------------------------------------------

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 是否启用调试模式
DEBUG=False

# --------------------------------------------
# 高级配置（选填，通常保持默认）
# --------------------------------------------

# 对话历史保留条数
MAX_HISTORY=100

# 消息去重时间窗口（秒）
DUPLICATION_WINDOW=20

# 系统通知去重窗口（秒）
SYSTEM_NOTICE_WINDOW=60
